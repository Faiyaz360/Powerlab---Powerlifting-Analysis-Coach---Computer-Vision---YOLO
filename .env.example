# Copy this file to `.env` (which is git-ignored) and fill in what you need.
# Everything here is OPTIONAL — the app runs fully without any of it.

# --- LLM coaching (optional) ---------------------------------------------------
# Without a key, coaching falls back to built-in, vetted rule-based cues.
# The LLM only PHRASES faults the deterministic pipeline already detected — it
# never invents faults. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Override the coaching model (optional). Default: anthropic/claude-sonnet-4.6
COACH_MODEL=

# --- Pose backend (optional) ---------------------------------------------------
# "yolo"      = YOLO pose on GPU (sharper, needs torch + ultralytics)
# "mediapipe" = MediaPipe BlazePose on CPU (the zero-setup default)
# Auto-detects on Hugging Face Spaces; set this to force one.
POSE_BACKEND=

# --- Leaderboard persistence (optional, Hugging Face Spaces only) ---------------
# Directory the SQLite leaderboard DB is snapshotted to (a mounted storage
# bucket). Leave blank for local use.
PERSIST_DIR=
